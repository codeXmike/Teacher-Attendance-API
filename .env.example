# Server Configuration
PORT=4000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/attendance_platform

# JWT
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# Client URLs (comma-separated for CORS)
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:3000

# Session Configuration
SESSION_TOKEN_TTL_SECONDS=90
SESSION_ROTATION_SECONDS=75
DEFAULT_ATTENDANCE_RADIUS_METERS=100
